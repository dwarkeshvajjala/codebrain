GROQ_API_KEY=your_groq_key_here

# Optional: choose a stronger Groq model for deeper code reasoning.
# GROQ_MODEL=openai/gpt-oss-120b

# Optional future persistence/vector search.
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
DATABASE_URL=postgresql://postgres:your_password@your_host:5432/postgres
# Remote markdown storage. Leave provider as auto: Supabase is preferred for markdown/JSON,
# Cloudinary is also supported for raw markdown files.
BRAIN_STORAGE_PROVIDER=auto
BRAIN_PROJECT_SOURCE=auto
BRAIN_STORAGE_BUCKET=code-brain
BRAIN_REMOTE_PREFIX=code-brain
# BRAIN_REMOTE_MANIFEST_URL=https://your-public-manifest-url/manifest.json
# BRAIN_REMOTE_TIMEOUT_MS=8000

# Supabase Storage credentials. Prefer a service role key on the server so the app can
# create the public bucket and upsert markdown files automatically.
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Cloudinary raw-file storage fallback.
# CLOUDINARY_CLOUD_NAME=your_cloud_name_here
# CLOUDINARY_API_KEY=your_cloudinary_api_key_here
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
